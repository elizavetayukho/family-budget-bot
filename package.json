{
  "name": "family-budget",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "bot",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:bot\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:bot": "npm run dev --workspace=bot",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web && npm run build --workspace=api && npm run build --workspace=bot",
    "start": "concurrently \"node api/dist/index.js\" \"node bot/dist/index.js\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.25.12": true,
    "prisma@5.22.0": true,
    "fsevents@2.3.3": true
  }
}
